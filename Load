package com.mphasis.usermanagementservice.controller;

import com.mphasis.usermanagementservice.dto.FileLoadRequestDto;
import com.mphasis.usermanagementservice.dto.FileLoadResponseDto;
import com.mphasis.usermanagementservice.service.FileLoadService;

import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.security.SecurityRequirement;

import lombok.RequiredArgsConstructor;

import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@RequestMapping("/api/file-loads")
@RequiredArgsConstructor
@SecurityRequirement(name = "bearerAuth")
public class FileLoadController {

    private final FileLoadService fileLoadService;

    // CREATE FILE LOAD
    @Operation(summary = "Create File Load")
    @PreAuthorize("hasAnyRole('ADMIN','USER')")
    @PostMapping
    public ResponseEntity<FileLoadResponseDto> createFileLoad(
            @RequestBody FileLoadRequestDto requestDto) {

        FileLoadResponseDto response =
                fileLoadService.createFileLoad(requestDto);

        return new ResponseEntity<>(
                response,
                HttpStatus.CREATED);
    }

    // GET FILE LOAD BY ID
    @Operation(summary = "Get File Load By Id")
    @PreAuthorize("hasAnyRole('ADMIN','USER')")
    @GetMapping("/{id}")
    public ResponseEntity<FileLoadResponseDto> getFileLoad(
            @PathVariable Long id) {

        FileLoadResponseDto response =
                fileLoadService.getFileLoad(id);

        return ResponseEntity.ok(response);
    }

    // SEARCH FILE LOADS
    @Operation(summary = "Search File Loads")
    @PreAuthorize("hasAnyRole('ADMIN','USER')")
    @GetMapping
    public ResponseEntity<List<FileLoadResponseDto>>
    searchFileLoads() {

        List<FileLoadResponseDto> response =
                fileLoadService.searchFileLoads();

        return ResponseEntity.ok(response);
    }

    // UPDATE STATUS
    @Operation(summary = "Update File Load Status")
    @PreAuthorize("hasRole('ADMIN')")
    @PutMapping("/{id}/status")
    public ResponseEntity<FileLoadResponseDto>
    updateFileLoadStatus(

            @PathVariable Long id,

            @RequestParam String status) {

        FileLoadResponseDto response =
                fileLoadService
                        .updateFileLoadStatus(id, status);

        return ResponseEntity.ok(response);
    }

    // DELETE FILE LOAD
    @Operation(summary = "Delete File Load")
    @PreAuthorize("hasRole('ADMIN')")
    @DeleteMapping("/{id}")
    public ResponseEntity<String> deleteFileLoad(
            @PathVariable Long id) {

        fileLoadService.deleteFileLoad(id);

        return ResponseEntity.ok(
                "File Load Deleted Successfully");
    }

    // ARCHIVE FILE LOAD
    @Operation(summary = "Archive File Load")
    @PreAuthorize("hasRole('ADMIN')")
    @PostMapping("/{id}/archive")
    public ResponseEntity<String> archiveFileLoad(
            @PathVariable Long id) {

        fileLoadService.archiveFileLoad(id);

        return ResponseEntity.ok(
                "File Load Archived Successfully");
    }
}




