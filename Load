package com.mphasis.usermanagementservice.service.impl;

import com.mphasis.usermanagementservice.dto.FileLoadRequestDto;
import com.mphasis.usermanagementservice.dto.FileLoadResponseDto;
import com.mphasis.usermanagementservice.entity.FileLoad;
import com.mphasis.usermanagementservice.repository.FileLoadRepository;
import com.mphasis.usermanagementservice.service.FileLoadService;

import lombok.RequiredArgsConstructor;

import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.util.List;
import java.util.stream.Collectors;

@Service
@RequiredArgsConstructor
public class FileLoadServiceImpl
        implements FileLoadService {

    private final FileLoadRepository repository;

    @Override
    public FileLoadResponseDto createFileLoad(
            FileLoadRequestDto requestDto) {

        FileLoad fileLoad = new FileLoad();

        fileLoad.setFilename(requestDto.getFilename());
        fileLoad.setStatus(requestDto.getStatus());
        fileLoad.setRecordCount(
                requestDto.getRecordCount());

        fileLoad.setLoadDate(LocalDateTime.now());

        repository.save(fileLoad);

        return mapToDto(fileLoad);
    }

    @Override
    public FileLoadResponseDto getFileLoad(Long id) {

        FileLoad fileLoad =
                repository.findById(id)
                        .orElseThrow(() ->
                                new RuntimeException(
                                        "File Load Not Found"));

        return mapToDto(fileLoad);
    }

    @Override
    public List<FileLoadResponseDto>
    searchFileLoads() {

        return repository.findAll()
                .stream()
                .map(this::mapToDto)
                .collect(Collectors.toList());
    }

    @Override
    public FileLoadResponseDto updateFileLoadStatus(
            Long id,
            String status) {

        FileLoad fileLoad =
                repository.findById(id)
                        .orElseThrow(() ->
                                new RuntimeException(
                                        "File Load Not Found"));

        fileLoad.setStatus(status);

        repository.save(fileLoad);

        return mapToDto(fileLoad);
    }

    @Override
    public void deleteFileLoad(Long id) {

        repository.deleteById(id);
    }

    @Override
    public void archiveFileLoad(Long id) {

        FileLoad fileLoad =
                repository.findById(id)
                        .orElseThrow(() ->
                                new RuntimeException(
                                        "File Load Not Found"));

        fileLoad.setStatus("ARCHIVED");

        repository.save(fileLoad);
    }

    private FileLoadResponseDto mapToDto(
            FileLoad fileLoad) {

        FileLoadResponseDto dto =
                new FileLoadResponseDto();

        dto.setId(fileLoad.getId());
        dto.setFilename(fileLoad.getFilename());
        dto.setStatus(fileLoad.getStatus());
        dto.setRecordCount(
                fileLoad.getRecordCount());

        dto.setLoadDate(fileLoad.getLoadDate());

        return dto;
    }
}

