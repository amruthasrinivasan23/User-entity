package com.mphasis.usermanagementservice.service;

import com.mphasis.usermanagementservice.entity.TradeFile;
import com.mphasis.usermanagementservice.repository.TradeFileRepository;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import java.io.BufferedReader;
import java.io.InputStreamReader;

@Service
public class FileService {

    @Autowired
    private TradeFileRepository repository;

    public void saveFileData(MultipartFile file) {

        try {

            BufferedReader reader =
                    new BufferedReader(
                            new InputStreamReader(file.getInputStream()));

            String line;
            int lineNumber = 0;

            while ((line = reader.readLine()) != null) {

                lineNumber++;

                String[] data;

                // CSV file
                if (file.getOriginalFilename().endsWith(".csv")) {

                    data = line.split(",");

                } else {

                    // TXT file with pipe separated values
                    data = line.split("\\|");
                }

                // Validation 1 : field count
                if (data.length < 4) {

                    System.out.println(
                            "Invalid field count at line " + lineNumber);

                    continue;
                }

                // Validation 2 : empty values
                if (data[0].trim().isEmpty()
                        || data[1].trim().isEmpty()
                        || data[2].trim().isEmpty()
                        || data[3].trim().isEmpty()) {

                    System.out.println(
                            "Empty field found at line " + lineNumber);

                    continue;
                }

                Long amount;

                // Validation 3 : amount number validation
                try {

                    amount = Long.parseLong(data[3]);

                } catch (Exception e) {

                    System.out.println(
                            "Invalid amount at line " + lineNumber);

                    continue;
                }

                // Validation 4 : positive amount
                if (amount <= 0) {

                    System.out.println(
                            "Amount must be positive at line " + lineNumber);

                    continue;
                }

                // Save valid data
                TradeFile trade = new TradeFile();

                trade.setSymbol(data[0].trim());
                trade.setMaActNum(data[1].trim());
                trade.setDescription(data[2].trim());
                trade.setAmount(amount);

                repository.save(trade);

                System.out.println(
                        "Record saved successfully at line " + lineNumber);
            }

            reader.close();

        } catch (Exception e) {

            e.printStackTrace();
        }
    }
}
