package com.mphasis.usermanagementservice.service;

import com.mphasis.usermanagementservice.entity.TradeFile;
import com.mphasis.usermanagementservice.repository.TradeFileRepository;

import org.springframework.beans.factory.annotationAutowired;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.math.BigDecimal;

@Service
public class FileService {

    @Autowired
    private TradeFileRepository repository;

    public void saveFileData(MultipartFile file) {

        try {

            BufferedReader reader =
                    new BufferedReader(
                            new InputStreamReader(file.getInputStream()));

            String line;

            while ((line = reader.readLine()) != null) {

                String[] data;

                if (file.getOriginalFilename().endsWith(".csv")) {
                    data = line.split(",");
                } else {
                    data = line.split("\\|");
                }

                if (data.length < 4) {
                    continue;
                }

                TradeFile trade = new TradeFile();

                trade.setSYMBOL(data[0]);
                trade.setMA_ACT_NUM(data[1]);
                trade.setDESCRIPTION(data[2]);
                trade.setAMOUNT(new BigDecimal(data[3]));

                repository.save(trade);
            }

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
